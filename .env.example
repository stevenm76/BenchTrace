# BenchTrace environment template — copy to `.env.local` and fill in.
# NEVER commit a real .env file. Values here are placeholders only.

# OpenAI-compatible server BenchTrace drives / imports from.
BENCHTRACE_BASE_URL=http://localhost:8000/v1

# API key for the upstream server, if it requires one. Leave blank for none.
BENCHTRACE_API_KEY=

# Where the local SQLite trace DB lives. Defaults to ./benchtrace.db if unset.
BENCHTRACE_DB_PATH=./benchtrace.db

# Opt in to downloading the ShareGPT dataset for the sharegpt prompt source.
BENCHTRACE_ACCEPT_SHAREGPT=

# Dev server port (Next.js). Defaults to 18000.
PORT=18000

# Engine version label stamped into imported bundles when not otherwise known.
VLLM_VERSION=
